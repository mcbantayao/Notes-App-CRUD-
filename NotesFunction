import json
import boto3
import uuid
from datetime import datetime  # ✅ added

dynamodb = boto3.resource('dynamodb')
table = dynamodb.Table('NotesTable')

def lambda_handler(event, context):
    method = event['httpMethod']

    # ✅ safe body parsing (prevents errors on GET)
    body = {}
    if event.get('body'):
        body = json.loads(event['body'])

    try:
        if method == 'POST':
            note_id = str(uuid.uuid4())
            now = datetime.utcnow().isoformat()  # ✅ timestamp

            table.put_item(Item={
                'id': note_id,
                'content': body.get('content', ''),
                'createdAt': now,   # ✅ added
                'updatedAt': now    # ✅ added
            })

            return response(200, {'message': 'Note created', 'id': note_id})

        elif method == 'GET':
            result = table.scan()
            return response(200, result.get('Items', []))  # ✅ safer

        elif method == 'PUT':
            table.update_item(
                Key={'id': body['id']},
                UpdateExpression='SET content = :c, updatedAt = :u',  # ✅ updated
                ExpressionAttributeValues={
                    ':c': body['content'],
                    ':u': datetime.utcnow().isoformat()  # ✅ timestamp update
                }
            )

            return response(200, {'message': 'Note updated'})

        elif method == 'DELETE':
            table.delete_item(Key={'id': body['id']})
            return response(200, {'message': 'Note deleted'})

        return response(400, {'message': 'Invalid request'})

    except Exception as e:
        print("ERROR:", str(e))  # 🔥 helps debugging
        return response(500, {'error': str(e)})


def response(status, body):
    return {
        'statusCode': status,
        'headers': {
            'Content-Type': 'application/json',
            'Access-Control-Allow-Origin': '*'
        },
        'body': json.dumps(body)
    }
